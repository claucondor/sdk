{
  "name": "@claucondor/sdk",
  "version": "0.6.8",
  "description": "Multi-token privacy SDK for Flow — JanusFlow (native FLOW), JanusWFLOW (ERC20), JanusMockUSDC (ERC20), JanusFT (Cadence FT generic wrapper). Pedersen commitments, Groth16 proofs, ECIES notes+snapshots, full wrap/shieldedTransfer/unwrap orchestration. Frontend-dumb: all crypto ordering lives in the SDK.",
  "author": "oydual3 <claucondor@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./primitives": {
      "import": "./dist/primitives/index.js",
      "require": "./dist/primitives/index.cjs",
      "types": "./dist/primitives/index.d.ts"
    },
    "./network": {
      "import": "./dist/network/index.js",
      "require": "./dist/network/index.cjs",
      "types": "./dist/network/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto/index.js",
      "require": "./dist/crypto/index.cjs",
      "types": "./dist/crypto/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs",
      "types": "./dist/utils/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs",
      "types": "./dist/adapters/index.d.ts"
    },
    "./orchestration": {
      "import": "./dist/orchestration/index.js",
      "require": "./dist/orchestration/index.cjs",
      "types": "./dist/orchestration/index.d.ts"
    },
    "./scan": {
      "import": "./dist/scan/index.js",
      "require": "./dist/scan/index.cjs",
      "types": "./dist/scan/index.d.ts"
    }
  },
  "files": [
    "dist",
    "circuits/v0.3",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "RUN_INTEGRATION=1 vitest run tests/integration",
    "test:all": "RUN_INTEGRATION=1 vitest run",
    "test:e2e": "RUN_E2E=1 vitest run tests/e2e",
    "test:watch": "vitest tests/unit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@onflow/fcl": "^1.13.0",
    "@onflow/types": "^1.4.1",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.13.4",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "flow",
    "blockchain",
    "cryptography",
    "babyjub",
    "pedersen",
    "groth16",
    "zk",
    "privacy",
    "claucondor",
    "confidential-transfer",
    "janus-token",
    "janus-flow",
    "shielded-transfer",
    "amount-disclose",
    "cross-vm",
    "cadence"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/claucondor/sdk.git"
  },
  "homepage": "https://github.com/claucondor/sdk#readme",
  "bugs": {
    "url": "https://github.com/claucondor/sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
