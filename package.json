{
  "name": "@claucondor/sdk",
  "version": "0.8.1-alpha.7",
  "description": "Multi-token privacy SDK for Flow v0.8 — JanusFlow (native FLOW), JanusERC20 (ERC20), JanusFT (Cadence FT). ShieldedInbox + ShieldedCheckpoint primitives, schema-agnostic ECIES, Pedersen commitments, Groth16 proofs, full wrap/shieldedTransfer/unwrap orchestration.",
  "author": "oydual3 <claucondor@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./primitives": {
      "import": "./dist/primitives/index.js",
      "require": "./dist/primitives/index.cjs",
      "types": "./dist/primitives/index.d.ts"
    },
    "./network": {
      "import": "./dist/network/index.js",
      "require": "./dist/network/index.cjs",
      "types": "./dist/network/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto/index.js",
      "require": "./dist/crypto/index.cjs",
      "types": "./dist/crypto/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs",
      "types": "./dist/utils/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs",
      "types": "./dist/adapters/index.d.ts"
    },
    "./orchestration": {
      "import": "./dist/orchestration/index.js",
      "require": "./dist/orchestration/index.cjs",
      "types": "./dist/orchestration/index.d.ts"
    },
    "./inbox": {
      "import": "./dist/inbox/index.js",
      "require": "./dist/inbox/index.cjs",
      "types": "./dist/inbox/index.d.ts"
    },
    "./checkpoint": {
      "import": "./dist/checkpoint/index.js",
      "require": "./dist/checkpoint/index.cjs",
      "types": "./dist/checkpoint/index.d.ts"
    },
    "./cadence": {
      "import": "./dist/cadence/index.js",
      "require": "./dist/cadence/index.cjs",
      "types": "./dist/cadence/index.d.ts"
    },
    "./batchClaim": {
      "import": "./dist/batchClaim/index.js",
      "require": "./dist/batchClaim/index.cjs",
      "types": "./dist/batchClaim/index.d.ts"
    },
    "./proof/batch-claim": {
      "import": "./dist/proof/batch-claim.js",
      "require": "./dist/proof/batch-claim.cjs",
      "types": "./dist/proof/batch-claim.d.ts"
    }
  },
  "files": [
    "dist",
    "circuits/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "RUN_INTEGRATION=1 vitest run tests/integration",
    "test:all": "RUN_INTEGRATION=1 vitest run",
    "test:e2e": "RUN_E2E=1 vitest run tests/e2e",
    "test:watch": "vitest tests/unit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/hashes": "^1.7.0",
    "@onflow/fcl": "^1.13.0",
    "@onflow/types": "^1.4.1",
    "@openjanus/commitment": "file:../openjanus-primitives/packages/commitment",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.13.4",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "flow",
    "blockchain",
    "cryptography",
    "babyjub",
    "pedersen",
    "groth16",
    "zk",
    "privacy",
    "claucondor",
    "confidential-transfer",
    "janus-token",
    "janus-flow",
    "shielded-transfer",
    "amount-disclose",
    "cross-vm",
    "cadence"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/claucondor/sdk.git"
  },
  "homepage": "https://github.com/claucondor/sdk#readme",
  "bugs": {
    "url": "https://github.com/claucondor/sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
