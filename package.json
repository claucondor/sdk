{
  "name": "@openjanus/sdk",
  "version": "0.2.0",
  "description": "Unified TypeScript SDK for OpenJanus privacy primitives on Flow — BabyJubJub, Pedersen, Groth16, extensible module architecture. v2 ElGamal-on-BabyJub token stack.",
  "author": "oydual3 <claucondor@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./primitives": {
      "import": "./dist/primitives/index.js",
      "require": "./dist/primitives/index.cjs",
      "types": "./dist/primitives/index.d.ts"
    },
    "./network": {
      "import": "./dist/network/index.js",
      "require": "./dist/network/index.cjs",
      "types": "./dist/network/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto/index.js",
      "require": "./dist/crypto/index.cjs",
      "types": "./dist/crypto/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "RUN_INTEGRATION=1 vitest run tests/integration",
    "test:all": "RUN_INTEGRATION=1 vitest run",
    "test:watch": "vitest tests/unit"
  },
  "dependencies": {
    "@onflow/fcl": "^1.13.0",
    "@onflow/types": "^1.4.1",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.13.4",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "flow",
    "blockchain",
    "cryptography",
    "babyjub",
    "pedersen",
    "groth16",
    "janus-token",
    "janus-flow",
    "zk",
    "privacy",
    "openjanus",
    "erc-7984",
    "confidential-transfer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openjanus/sdk.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
